{
  "routes": [
    {
      "route": "/api/*",
      "methods": [
        "get",
        "post",
        "put",
        "delete",
        "patch",
        "head",
        "connect",
        "trace",
        "options"
      ],
      "rewrite": "https://projectpilot.azurewebsites.net/api",
      "redirect": "https://projectpilot.azurewebsites.net/api",
      "allowedRoles": [
        "anonymous"
      ]
    }
  ]
}